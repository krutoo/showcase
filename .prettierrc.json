{
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "jsxSingleQuote": true,
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^node:",
    "^react",
    "<THIRD_PARTY_MODULES>",
    "^#(.*)$",
    "^[./]((?!.css$).)*$",
    "\\.css$"
  ],
  "importOrderSeparation": false,
  "importOrderSortSpecifiers": true
}
